APP_NAME=CloudSunny
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Ho_Chi_Minh

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cloudsunny
DB_USERNAME=root
DB_PASSWORD=

CLOUDSUNNY_API_BASE=https://api.cloudsunny.net/api
CLOUDSUNNY_API_USERNAME=
CLOUDSUNNY_API_APP_KEY=
CLOUDSUNNY_API_SECRET_KEY=
CLOUDSUNNY_DEFAULT_OS_ID=1
CLOUDSUNNY_DEFAULT_BILLING_CYCLE=monthly
CLOUDSUNNY_ADDON_CPU_MONTHLY=30000
CLOUDSUNNY_ADDON_RAM_MONTHLY=12000
CLOUDSUNNY_ADDON_DISK_10GB_MONTHLY=10000
CLOUDSUNNY_CACHE_TTL=300
